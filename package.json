{
  "name": "allure-testops-mcp",
  "version": "1.0.0",
  "description": "MCP server for Allure TestOps test cases and launches",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "allure-testops-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --ext .ts --fix",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "temp:test": "tsx scripts/temp-smoke-test.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "allure",
    "allure-testops"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
